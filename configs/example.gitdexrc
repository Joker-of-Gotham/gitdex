# Project-level configuration for gitdex
# Place this file as .gitdexrc in your project root
#
# Supported providers:
#   - ollama
#   - openai
#   - deepseek
#
# API keys are best supplied via environment variables.
# Examples:
#   OPENAI_API_KEY=...
#   DEEPSEEK_API_KEY=...

suggestion:
  mode: "zen"
  language: "auto"

llm:
  # Default provider values are inherited by primary/secondary roles unless
  # that role overrides them.
  provider: "ollama"
  endpoint: "http://localhost:11434"
  api_key_env: ""
  context_length: 32768
  request_timeout: 120

  primary:
    provider: "ollama"
    model: "qwen2.5:3b"
    endpoint: "http://localhost:11434"
    api_key_env: ""
    enabled: true

  secondary:
    provider: "ollama"
    model: ""
    endpoint: "http://localhost:11434"
    api_key_env: ""
    enabled: false

  # Example: OpenAI only
  # provider: "openai"
  # endpoint: "https://api.openai.com/v1"
  # api_key_env: "OPENAI_API_KEY"
  # primary:
  #   provider: "openai"
  #   model: "gpt-4.1-mini"
  #   endpoint: "https://api.openai.com/v1"
  #   api_key_env: "OPENAI_API_KEY"
  #   enabled: true

  # Example: DeepSeek only
  # provider: "deepseek"
  # endpoint: "https://api.deepseek.com"
  # api_key_env: "DEEPSEEK_API_KEY"
  # primary:
  #   provider: "deepseek"
  #   model: "deepseek-chat"
  #   endpoint: "https://api.deepseek.com"
  #   api_key_env: "DEEPSEEK_API_KEY"
  #   enabled: true

  # Example: mixed primary + verifier
  # primary:
  #   provider: "openai"
  #   model: "gpt-4.1-mini"
  #   endpoint: "https://api.openai.com/v1"
  #   api_key_env: "OPENAI_API_KEY"
  #   enabled: true
  # secondary:
  #   provider: "ollama"
  #   model: "qwen2.5:7b"
  #   endpoint: "http://localhost:11434"
  #   enabled: true

sync:
  auto_fetch_interval: 300

automation:
  enabled: false
  monitor_interval: 300
  auto_analyze: true
  unattended: false
  auto_accept_safe: false
  trusted_mode: false
  max_auto_steps: 8
  schedules: []

  # Conservative unattended example:
  # enabled: true
  # monitor_interval: 180
  # auto_analyze: true
  # unattended: true
  # auto_accept_safe: true
  # trusted_mode: true
  # max_auto_steps: 6
  # schedules:
  #   - id: "security-audit"
  #     enabled: true
  #     workflow_id: "advanced_security"
  #     interval: 3600
  #   - id: "repo-health"
  #     enabled: true
  #     goal: "Run a comprehensive repository health check and surface the next safe actions."
  #     interval: 1800

adapters:
  git:
    enabled: true
    binary: "git"
  github:
    gh:
      enabled: true
      binary: "gh"
    browser:
      enabled: false
      driver: "default"
  gitlab:
    browser:
      enabled: false
      driver: "default"
  bitbucket:
    browser:
      enabled: false
      driver: "default"

i18n:
  language: "auto"
